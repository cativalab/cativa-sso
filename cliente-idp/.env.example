# Porta local do IdP
PORT=4010

# URL PUBLICA pela qual a Cativa (prod) alcanca este IdP.
# localhost NAO funciona: a Cativa busca discovery/jwks/token server-side.
# Suba um tunel e cole a URL aqui (sem barra final). Exemplos:
#   cloudflared tunnel --url http://localhost:4010
#   ngrok http 4010
PUBLIC_URL=http://localhost:4010

# Credenciais do client que a Cativa vai usar (registre as MESMAS no admin do tenant).
CLIENT_ID=cativa-federated-demo
CLIENT_SECRET=super-secret-demo

# Usuario de demonstracao que este IdP "autentica".
DEMO_SUB=user-123
DEMO_EMAIL=demo@cliente.com
DEMO_GIVEN_NAME=Demo
DEMO_FAMILY_NAME=Cliente
DEMO_PICTURE=
