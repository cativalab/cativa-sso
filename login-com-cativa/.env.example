# Base OIDC da Cativa em producao (NAO inclua a barra final)
CATIVA_API_BASE=https://apis.cativalab.digital/tenant/api/v2

# Slug do tenant/customer (ex.: makersday)
CUSTOMER=makersday

# Porta local e redirect_uri deste app
PORT=4000
REDIRECT_URI=http://localhost:4000/callback

# Opcional: se ja tiver um client registrado, fixe aqui e o app NAO faz Dynamic Client Registration.
# Se deixar vazio, o app se auto-registra via /sso/{customer}/register no boot e imprime as credenciais.
CLIENT_ID=
CLIENT_SECRET=

# Escopos solicitados
SCOPE=openid profile email
